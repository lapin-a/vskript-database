  "syntax_1220": {
    "id": 1220,
    "creator": "Pikachu",
    "title": "On Placeholder Request",
    "description": "Called when a placeholder is requested. This can be used to make your own placeholders like this:\r\n```\r\non placeholder request with prefix \"custom\":\r\n  if the identifier is \"hey\": # %custom_hey%\r\n    set the result to \"hi there %player%!\"\r\n  else if the identifier is \"bye\": # %custom_bye%\r\n    set the result to \"bye bye %player%\"\r\n```",
    "syntax_pattern": "[on] (placeholder[api]|papi) request with [the] prefix %string%",
    "compatible_addon_version": null,
    "compatible_minecraft_version": null,
    "syntax_type": "event",
    "required_plugins": [
      {
        "name": "PlaceholderAPI",
        "link": "https://www.spigotmc.org/resources/placeholderapi.6245/"
      }
    ],
    "addon": "Ersatz",
    "type_usage": null,
    "return_type": null,
    "event_values": "event-string, event-player",
    "event_cancellable": false,
    "link": "http://skripthub.net/docs/?id=1220",
    "created_at": "2017-11-07T07:02:55.524518Z",
    "updated_at": "2017-11-08T01:25:38.649981Z",
    "entries": null,
    "keywords": null,
    "mark_as_removed": false,
    "removed_since": null,
    "guide": {
      "en": [
        "Called when a placeholder is requested. This can be used to make your own placeholders like this:\r\n```\r\non placeholder request with prefix \"custom\":\r\n  if the identifier is \"hey\": # %custom_hey%\r\n    set the result to \"hi there %player%!\"\r\n  else if the identifier is \"bye\": # %custom_bye%\r\n    set the result to \"bye bye %player%\"\r\n```"
      ],
      "ko": [
        "[ERSATZ] 한국어 가이드 번역 대기 중"
      ]
    }
  },
