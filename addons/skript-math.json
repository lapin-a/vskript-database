  "syntax_1573": {
    "id": 1573,
    "creator": "Syst3ms",
    "title": "Register Constant",
    "description": "Registers a constant (duh), which can be used in the evaluate expression (described in [Evaluating Expressions](https://github.com/Syst3ms/Skuared/wiki/Evaluating-Expressions)).\n A constant name must consist of one letter optionally followed by one or more letters or digits\n If that's any clearer to you, the regex Skuared uses is '[A-Za-z][A-Za-z\\\\d]*.'",
    "syntax_pattern": "register [new] constant [[with] symbol] %string% [(and|with)] value %number%",
    "compatible_addon_version": "1.0",
    "compatible_minecraft_version": null,
    "syntax_type": "effect",
    "required_plugins": [],
    "addon": "skript-math",
    "type_usage": null,
    "return_type": null,
    "event_values": null,
    "event_cancellable": false,
